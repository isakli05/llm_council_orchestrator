{
  "models": {
    "legacy_analysis": [
      {
        "model": "glm-4.6",
        "provider": "zai",
        "base_url": "https://api.z.ai/api/coding/paas/v4",
        "thinking": {
          "type": "enabled"
        }
      },
      {
        "model": "gpt-5.2",
        "provider": "openai",
        "reasoning": {
          "effort": "high"
        }
      }
    ],
    "architect": [
      {
        "model": "gpt-5.2",
        "provider": "openai",
        "reasoning": {
          "effort": "high"
        }
      },
      {
        "model": "claude-opus-4-5",
        "provider": "anthropic",
        "thinking": {
          "type": "enabled",
          "budget_tokens": 4096
        }
      }
    ],
    "migration": [
      {
        "model": "gpt-5.2",
        "provider": "openai",
        "reasoning": {
          "effort": "high"
        }
      }
    ],
    "security": [
      {
        "model": "claude-sonnet-4-5",
        "provider": "anthropic",
        "thinking": {
          "type": "enabled",
          "budget_tokens": 2048
        }
      }
    ],
    "aggregator": {
      "model": "gpt-5.2-pro",
      "provider": "openai",
      "reasoning": {
        "effort": "xhigh"
      }
    }
  },
  "providers": {
    "openai": {
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "envKey": "OPENAI_API_KEY",
      "timeout": 60000
    },
    "anthropic": {
      "endpoint": "https://api.anthropic.com/v1/messages",
      "envKey": "ANTHROPIC_API_KEY",
      "timeout": 90000
    },
    "zai": {
      "endpoint": "https://api.z.ai/api/coding/paas/v4/chat/completions",
      "envKey": "ZAI_API_KEY",
      "timeout": 60000
    },
    "gemini": {
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "envKey": "GEMINI_API_KEY",
      "timeout": 60000
    },
    "openai-openrouter": {
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "envKey": "OPENROUTER_API_KEY",
      "timeout": 90000
    },
    "anthropic-openrouter": {
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "envKey": "OPENROUTER_API_KEY",
      "timeout": 90000
    },
    "zai-openrouter": {
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "envKey": "OPENROUTER_API_KEY",
      "timeout": 90000
    },
    "gemini-openrouter": {
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "envKey": "OPENROUTER_API_KEY",
      "timeout": 90000
    }
  },
  "embedding": {
    "engine": "local-bge-large-v1.5",
    "dimensions": 1024,
    "endpoint": "http://localhost:8000/embeddings",
    "availableModels": {
      "local-bge-large-v1.5": {
        "dimensions": 1024,
        "maxTokens": 512
      },
      "multilingual-e5-large-instruct": {
        "dimensions": 1024,
        "maxTokens": 512
      },
      "bge-m3": {
        "dimensions": 1024,
        "maxTokens": 8192
      }
    }
  },
  "services": {
    "indexer": {
      "url": "http://localhost:9001",
      "timeout": 60000
    },
    "qdrant": {
      "url": "http://localhost:6333"
    }
  },
  "defaults": {
    "modelCallTimeout": 30000,
    "httpRequestTimeout": 120000,
    "maxRetries": 3,
    "backoffBase": 1000
  }
}
