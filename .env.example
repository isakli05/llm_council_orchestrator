# LLM Council Orchestrator - Environment Configuration
# Copy this file to .env and fill in your API keys
#
# This file documents all environment variables used by the LLM Council system.
# Required variables are marked with [REQUIRED], optional ones with [OPTIONAL].

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# [REQUIRED] OpenAI API Key (for gpt-5.2, gpt-5.2-pro)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# [REQUIRED] Anthropic API Key (for claude-opus-4-5, claude-sonnet-4-5)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# [OPTIONAL] Z.AI API Key (for glm-4.6)
# Required only if using Z.AI/GLM models
ZAI_API_KEY=your-zai-api-key-here

# [OPTIONAL] Gemini API Key (for gemini-3-pro)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# [OPTIONAL] OpenRouter API Key (for OpenRouter fallback/alternative routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# [OPTIONAL] OpenRouter Headers (for OpenRouter requests per Requirements 6.3)
# HTTP-Referer header for OpenRouter API requests
OPENROUTER_REFERER=https://llm-council.local
# X-Title header for OpenRouter API requests
OPENROUTER_TITLE=LLM Council Orchestrator

# ============================================================================
# Orchestrator Service Configuration
# ============================================================================

# [OPTIONAL] Orchestrator API port (default: 7001)
ORCH_PORT=7001

# [OPTIONAL] Orchestrator API host (default: 127.0.0.1)
ORCH_HOST=127.0.0.1

# [OPTIONAL] Orchestrator log level (debug, info, warn, error)
ORCH_LOG_LEVEL=info

# [OPTIONAL] Path to architect.config.json (defaults to project root)
ORCH_CONFIG_PATH=./architect.config.json

# [OPTIONAL] Path to spec output directory
ORCH_SPEC_ROOT=./apps/orchestrator/development_specs

# ============================================================================
# Indexer Service Configuration
# ============================================================================

# [REQUIRED for HTTP mode] Indexer service URL
INDEXER_URL=http://localhost:9001

# [REQUIRED] Indexer API key for authentication (Requirements 8.6, 8.7)
# Generate a secure random key for production
INDEXER_API_KEY=your-secure-indexer-api-key-here

# [OPTIONAL] Indexer service port (default: 9001)
INDEXER_PORT=9001

# [OPTIONAL] Indexer service host (default: 0.0.0.0)
INDEXER_HOST=0.0.0.0

# [OPTIONAL] Indexer storage path for persisting index data
INDEXER_STORAGE_PATH=./data/indexer

# [OPTIONAL] Indexer model name for embeddings
INDEXER_MODEL_NAME=bge-large

# [OPTIONAL] Indexer device for embeddings (cpu, gpu)
INDEXER_DEVICE=cpu

# ============================================================================
# Embedding Server Configuration
# ============================================================================

# [REQUIRED] Embedding server URL (OpenAI-compatible endpoint)
EMBEDDING_URL=http://localhost:8000

# [OPTIONAL] Embedding model to use (Requirements 9.1, 9.2, 9.3, 9.4)
# Options: local-bge-large-v1.5, multilingual-e5-large-instruct, bge-m3
# All models use 1024 dimensions for Qdrant compatibility
EMBEDDING_MODEL=local-bge-large-v1.5

# ============================================================================
# Qdrant Vector Store Configuration (OPTIONAL - Not Currently Used)
# ============================================================================
# NOTE: The indexer currently uses local file-based vector storage.
# Qdrant is included for future migration but is NOT in the critical data path.
# See apps/indexer/VECTOR_STORAGE_ARCHITECTURE.md for details.

# [OPTIONAL] Qdrant vector database URL (not currently used in data path)
QDRANT_URL=http://localhost:6333

# ============================================================================
# MCP Bridge Configuration
# ============================================================================

# [OPTIONAL] Orchestrator URL for MCP Bridge (default: http://localhost:7001)
ORCHESTRATOR_URL=http://localhost:7001

# ============================================================================
# Environment and Logging
# ============================================================================

# [REQUIRED] Node environment (development, production, test)
# In production: stack traces are stripped from API responses (Requirements 12.7)
NODE_ENV=development

# [OPTIONAL] Global log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Discovery Engine Configuration (Optional)
# ============================================================================

# [OPTIONAL] Maximum retries for discovery operations
DISCOVERY_MAX_RETRIES=3

# [OPTIONAL] Base backoff time in milliseconds for retry logic
DISCOVERY_BASE_BACKOFF_MS=1000

# [OPTIONAL] Low confidence threshold for domain classification
DISCOVERY_LOW_CONFIDENCE_THRESHOLD=0.3

# [OPTIONAL] Maximum directory depth for scanning
DISCOVERY_MAX_DIRECTORY_DEPTH=10

# [OPTIONAL] Enable pattern caching (true/false)
DISCOVERY_ENABLE_PATTERN_CACHE=true

# [OPTIONAL] Cache TTL in milliseconds
DISCOVERY_CACHE_TTL_MS=300000

# [OPTIONAL] Enable metrics collection (true/false)
DISCOVERY_ENABLE_METRICS=true

# [OPTIONAL] Enable detailed timing metrics (true/false)
DISCOVERY_ENABLE_DETAILED_TIMING=false

# [OPTIONAL] Batch size for signal processing
DISCOVERY_SIGNAL_BATCH_SIZE=100

# [OPTIONAL] Enable parallel processing (true/false)
DISCOVERY_ENABLE_PARALLEL_PROCESSING=true

# ============================================================================
# Advanced Configuration (Optional)
# ============================================================================
# 
# These environment variables OVERRIDE values from architect.config.json
# Per Requirements 15.2: Environment variables take precedence over config file values
#
# Configuration Priority (highest to lowest):
# 1. Environment variables (set here or in your shell)
# 2. architect.config.json values
# 3. Default values
#

# [OPTIONAL] Model call timeout in milliseconds (overrides defaults.modelCallTimeout)
# MODEL_CALL_TIMEOUT=30000

# [OPTIONAL] HTTP request timeout in milliseconds (overrides defaults.httpRequestTimeout)
# HTTP_REQUEST_TIMEOUT=600000

# [OPTIONAL] Maximum retries for failed requests (overrides defaults.maxRetries)
# MAX_RETRIES=2

# [OPTIONAL] Base delay for exponential backoff in milliseconds (overrides defaults.backoffBase)
# BACKOFF_BASE=1000

# [OPTIONAL] Indexer service timeout in milliseconds (overrides services.indexer.timeout)
# INDEXER_TIMEOUT=60000

# ============================================================================
# Memory Management (Requirements 13.x)
# ============================================================================
# Note: These are configured via code constants, not environment variables.
# Documented here for reference:
# - Trace cleanup interval: 15 minutes
# - Cache cleanup interval: 15 minutes
# - Active runs cleanup interval: 1 hour
# - Memory monitoring interval: 5 minutes
# - Heap usage threshold for aggressive cleanup: 80%
# - Maximum traces to keep: 100
# - LRU cache max size: 100

# ============================================================================
# Docker Compose Service URLs (for containerized deployment)
# ============================================================================
# When running with docker-compose, use these service names:
# INDEXER_URL=http://indexer:9001
# EMBEDDING_URL=http://embedding:8000
# QDRANT_URL=http://qdrant:6333
# ORCHESTRATOR_URL=http://orchestrator:7001
